{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/images/*.{png,jpg,gif}", "/css/*"]
  },
    "routes": [
    {
      "route": "/bakery/*",
      "serve": "/bakery/index.html"
    }
  ],
   "mimeTypes": {
    ".js": "application/javascript",
    ".css": "text/css",
    ".json": "application/json",
    ".html": "text/html"
    }
}
